NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/event-job-system

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue
QUEUE_NAME=job-processing

# Worker concurrency (jobs processed in parallel per worker instance)
WORKER_CONCURRENCY=5

# API service socket URL (for emitting events back)
API_SOCKET_URL=http://localhost:5000

# Logging
LOG_LEVEL=info

# Output directory for generated files
OUTPUT_DIR=./outputs
